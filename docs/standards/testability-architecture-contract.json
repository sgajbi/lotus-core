{
  "specVersion": "1.0.0",
  "application": "lotus-core",
  "protectedPathGlobs": [
    "src/services/**/app/domain/**/*.py",
    "src/services/**/app/application/**/*.py",
    "src/services/**/app/ports/**/*.py",
    "src/services/**/app/policies/**/*.py",
    "src/services/calculators/position_calculator/app/core/position_reducer.py"
  ],
  "forbiddenImportPrefixes": [
    "boto3",
    "botocore",
    "confluent_kafka",
    "fastapi",
    "httpx",
    "portfolio_common.db",
    "portfolio_common.kafka_utils",
    "redis",
    "requests",
    "sqlalchemy",
    "starlette"
  ],
  "forbiddenImportParts": [
    "adapters",
    "clients",
    "consumers",
    "dependencies",
    "infrastructure",
    "repositories",
    "repository",
    "routers"
  ],
  "forbiddenSymbols": [
    "APIRouter",
    "AsyncSession",
    "AsyncSessionLocal",
    "Depends",
    "FastAPI",
    "HTTPException",
    "KafkaProducer",
    "Request",
    "SessionLocal",
    "get_async_db_session",
    "get_kafka_producer"
  ],
  "approvedRuntimeCompositionPathPrefixes": [
    "src/services/*/app/dependencies.py",
    "src/services/*/app/main.py",
    "src/services/*/app/web.py",
    "src/services/*/app/routers/",
    "src/services/*/app/consumers/",
    "src/services/*/app/consumer_manager.py",
    "src/services/*/app/adapters/",
    "src/services/*/app/infrastructure/",
    "src/services/*/app/repositories/",
    "src/libs/portfolio-common/portfolio_common/db.py",
    "src/libs/portfolio-common/portfolio_common/kafka_utils.py",
    "src/libs/portfolio-common/portfolio_common/event_publisher.py",
    "src/libs/portfolio-common/portfolio_common/outbox_dispatcher.py",
    "src/libs/portfolio-common/portfolio_common/http_app_bootstrap.py",
    "src/libs/portfolio-common/portfolio_common/health.py"
  ]
}
