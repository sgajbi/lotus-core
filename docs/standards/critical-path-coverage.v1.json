{
  "schema_version": "critical-path-coverage.v1",
  "owning_repository": "lotus-core",
  "issue": "sgajbi/lotus-core#612",
  "aggregate_gate": {
    "command": "make coverage-gate",
    "minimum_line_coverage_percent": 98.0,
    "branch_coverage_required": true,
    "coverage_json": "output/coverage/coverage.json"
  },
  "changed_code_gate": {
    "base_ref_environment_variable": "LOTUS_COVERAGE_CHANGED_BASE",
    "default_base_ref": "origin/main",
    "minimum_measured_line_coverage_percent": 90.0,
    "unmeasured_critical_file_policy": "reported_requires_follow_up",
    "report_path": "output/coverage/critical-path-coverage-report.json"
  },
  "exception_policy": {
    "maximum_exception_days": 90,
    "required_fields": [
      "group_id",
      "path_glob",
      "reason",
      "owner",
      "follow_up_issue",
      "expires_on"
    ],
    "active_exceptions": []
  },
  "critical_path_groups": [
    {
      "id": "transaction_lifecycle",
      "title": "Transaction lifecycle and transaction type handling",
      "risk": "Incorrect lifecycle or transaction-type behavior can corrupt booking state, replay behavior, and downstream analytics inputs.",
      "source_globs": [
        "src/libs/portfolio-common/portfolio_common/transaction_domain/**/*.py",
        "src/libs/portfolio-common/portfolio_common/transaction_type_registry.py",
        "src/services/ingestion_service/app/domain/**/*.py",
        "src/services/ingestion_service/app/services/ingestion_job_lifecycle*.py",
        "src/services/query_service/app/services/transaction*.py"
      ],
      "minimum_measured_line_coverage_percent": 92.0,
      "minimum_measured_branch_coverage_percent": 85.0,
      "branch_coverage_required": true,
      "expected_test_families": [
        "domain",
        "transaction-contract",
        "integration-contract"
      ],
      "required_manifest_suites": [
        "transaction-buy-contract",
        "transaction-sell-contract",
        "transaction-dividend-contract",
        "transaction-interest-contract",
        "transaction-fx-contract",
        "ops-contract"
      ],
      "required_test_globs": [
        "tests/unit/transaction_specs/test_*_slice0_characterization.py",
        "tests/unit/libs/portfolio_common/test_*_validation.py",
        "tests/unit/services/ingestion_service/domain/test_ingestion_job_lifecycle_policy.py",
        "tests/integration/services/ingestion_service/test_ingestion_routers.py"
      ]
    },
    {
      "id": "financial_calculations",
      "title": "Cost basis, P&L, cashflow, accrued income, valuation, price, and FX calculations",
      "risk": "Weak calculation coverage can produce incorrect client economics while aggregate coverage remains stable.",
      "source_globs": [
        "src/libs/portfolio-common/portfolio_common/cost_basis.py",
        "src/libs/portfolio-common/portfolio_common/fx_rates.py",
        "src/libs/portfolio-common/portfolio_common/valuation*.py",
        "src/services/calculators/cost_calculator_service/app/**/*.py",
        "src/services/calculators/cashflow_calculator_service/app/**/*.py",
        "src/services/calculators/position_valuation_calculator/app/**/*.py",
        "src/services/query_service/app/advisory_simulation/valuation.py",
        "src/services/query_service/app/services/fx*.py",
        "src/services/query_service/app/services/price*.py",
        "src/services/query_service/app/services/cashflow*.py"
      ],
      "minimum_measured_line_coverage_percent": 92.0,
      "minimum_measured_branch_coverage_percent": 85.0,
      "branch_coverage_required": true,
      "expected_test_families": [
        "domain",
        "calculation",
        "integration-contract"
      ],
      "required_manifest_suites": [
        "transaction-buy-contract",
        "transaction-sell-contract",
        "transaction-dividend-contract",
        "transaction-interest-contract",
        "transaction-fx-contract",
        "transaction-portfolio-flow-bundle-contract"
      ],
      "required_test_globs": [
        "tests/unit/services/calculators/cost_calculator_service/**/*.py",
        "tests/unit/services/calculators/cashflow_calculator_service/**/*.py",
        "tests/unit/services/calculators/position_valuation_calculator/**/*.py",
        "tests/integration/services/calculators/**/*.py"
      ]
    },
    {
      "id": "position_cash_state",
      "title": "Position, cash ledger, and state-transition behavior",
      "risk": "Untested position or cash state transitions can create incorrect holdings, cash balances, and replay decisions.",
      "source_globs": [
        "src/services/calculators/position_calculator/app/core/**/*.py",
        "src/services/query_service/app/services/position*.py",
        "src/services/query_service/app/services/cash*.py",
        "src/services/query_service/app/repositories/position_repository.py",
        "src/services/query_service/app/repositories/cash*.py",
        "src/libs/portfolio-common/portfolio_common/position_state_repository.py"
      ],
      "minimum_measured_line_coverage_percent": 92.0,
      "minimum_measured_branch_coverage_percent": 85.0,
      "branch_coverage_required": true,
      "expected_test_families": [
        "domain",
        "state-transition",
        "repository"
      ],
      "required_manifest_suites": [
        "transaction-portfolio-flow-bundle-contract",
        "unit-db",
        "integration-lite"
      ],
      "required_test_globs": [
        "tests/unit/services/calculators/position_calculator/**/*.py",
        "tests/unit/services/query_service/services/test_position*.py",
        "tests/unit/services/query_service/routers/test_cash_movements_router.py",
        "tests/integration/services/query_service/test_*cash*.py"
      ]
    },
    {
      "id": "corporate_actions",
      "title": "Corporate-action handling",
      "risk": "Corporate-action handling needs explicit domain tests because it changes quantity, cash, and cost state through non-trade events.",
      "source_globs": [
        "src/libs/portfolio-common/portfolio_common/transaction_domain/ca_*.py",
        "src/services/calculators/position_calculator/app/core/position_reducer.py",
        "src/services/calculators/position_calculator/app/core/position_logic.py"
      ],
      "minimum_measured_line_coverage_percent": 90.0,
      "minimum_measured_branch_coverage_percent": 82.0,
      "branch_coverage_required": true,
      "expected_test_families": [
        "domain",
        "state-transition"
      ],
      "required_manifest_suites": [
        "transaction-portfolio-flow-bundle-contract",
        "transaction-fx-contract"
      ],
      "required_test_globs": [
        "tests/unit/libs/portfolio_common/test_portfolio_flow_guardrails.py",
        "tests/unit/services/calculators/position_calculator/core/test_position_reducer.py",
        "tests/unit/services/calculators/position_calculator/core/test_position_logic.py"
      ]
    },
    {
      "id": "auth_audit_security",
      "title": "Authorization, audit, security middleware, and sensitive-data handling",
      "risk": "Security and audit regressions can expose sensitive portfolio data or make incident evidence incomplete.",
      "source_globs": [
        "src/libs/portfolio-common/portfolio_common/enterprise_readiness.py",
        "src/libs/portfolio-common/portfolio_common/http_app_bootstrap.py",
        "src/libs/portfolio-common/portfolio_common/source_data_security.py",
        "src/services/**/app/enterprise_readiness.py",
        "src/services/**/app/request_metadata.py"
      ],
      "minimum_measured_line_coverage_percent": 95.0,
      "minimum_measured_branch_coverage_percent": 90.0,
      "branch_coverage_required": true,
      "expected_test_families": [
        "security",
        "contract",
        "observability"
      ],
      "required_manifest_suites": [
        "unit",
        "ops-contract"
      ],
      "required_test_globs": [
        "tests/unit/libs/portfolio-common/test_enterprise_readiness_shared.py",
        "tests/unit/libs/portfolio-common/test_http_app_bootstrap.py",
        "tests/unit/libs/portfolio-common/test_source_data_security.py",
        "tests/unit/test_http_middleware_chain_contract.py",
        "tests/unit/scripts/test_security_control_coverage_guard.py"
      ]
    },
    {
      "id": "ingestion_replay_outbox",
      "title": "Ingestion, replay, outbox, and job lifecycle orchestration",
      "risk": "Weak workflow coverage can lose jobs, acknowledge failed replay/audit work, or hide DLQ recovery defects.",
      "source_globs": [
        "src/services/ingestion_service/app/application/**/*.py",
        "src/services/ingestion_service/app/services/ingestion*.py",
        "src/services/ingestion_service/app/infrastructure/**/*.py",
        "src/services/event_replay_service/app/application/**/*.py",
        "src/services/event_replay_service/app/routers/**/*.py",
        "src/libs/portfolio-common/portfolio_common/outbox*.py",
        "src/libs/portfolio-common/portfolio_common/reprocessing*.py"
      ],
      "minimum_measured_line_coverage_percent": 92.0,
      "minimum_measured_branch_coverage_percent": 85.0,
      "branch_coverage_required": true,
      "expected_test_families": [
        "application",
        "integration-contract",
        "resilience"
      ],
      "required_manifest_suites": [
        "unit",
        "ops-contract",
        "integration-lite"
      ],
      "required_test_globs": [
        "tests/unit/services/ingestion_service/**/*.py",
        "tests/unit/services/event_replay_service/**/*.py",
        "tests/integration/services/ingestion_service/test_ingestion_routers.py",
        "tests/integration/libs/portfolio-common/test_outbox_dispatcher*.py"
      ]
    },
    {
      "id": "repository_database_hot_paths",
      "title": "Repository, database, and migration-sensitive hot paths",
      "risk": "Database hot-path changes need repository and migration-sensitive tests because SQL shape, pagination, and transaction boundaries are high-blast-radius.",
      "source_globs": [
        "src/services/**/app/repositories/**/*.py",
        "src/services/**/app/repositories/*.py",
        "src/services/persistence_service/app/**/*.py",
        "src/libs/portfolio-common/portfolio_common/*repository*.py",
        "alembic/**/*.py"
      ],
      "minimum_measured_line_coverage_percent": 88.0,
      "minimum_measured_branch_coverage_percent": 80.0,
      "branch_coverage_required": true,
      "expected_test_families": [
        "repository",
        "database",
        "migration-smoke"
      ],
      "required_manifest_suites": [
        "unit-db",
        "integration-lite",
        "integration-all"
      ],
      "required_test_globs": [
        "tests/unit/services/query_service/repositories/**/*.py",
        "tests/integration/services/query_service/test_*repository*.py",
        "tests/integration/services/persistence_service/**/*.py"
      ]
    },
    {
      "id": "api_contract_error_mapping",
      "title": "API request/response contracts and error mapping",
      "risk": "API contract and error-mapping changes can silently break downstream services even when implementation coverage is high.",
      "source_globs": [
        "src/services/**/app/routers/**/*.py",
        "src/services/**/app/routers/*.py",
        "src/services/**/app/dtos/**/*.py",
        "src/services/**/app/DTOs/**/*.py",
        "src/services/**/app/main.py",
        "src/services/**/app/web.py"
      ],
      "minimum_measured_line_coverage_percent": 92.0,
      "minimum_measured_branch_coverage_percent": 85.0,
      "branch_coverage_required": true,
      "expected_test_families": [
        "api-contract",
        "integration-contract",
        "openapi"
      ],
      "required_manifest_suites": [
        "integration-lite",
        "ops-contract",
        "unit"
      ],
      "required_test_globs": [
        "tests/unit/services/**/routers/**/*.py",
        "tests/integration/services/query_service/test_*router*.py",
        "tests/integration/services/ingestion_service/test_ingestion_routers.py",
        "tests/unit/services/query_service/routers/test_http_errors.py"
      ]
