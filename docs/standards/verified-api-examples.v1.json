    {
      "id": "operational-read-success",
      "category": "success",
      "service": "query_service",
      "family": "Operational Read",
      "method": "GET",
      "path": "/portfolios/{portfolio_id}/positions",
      "sourceTests": [
        "tests/integration/services/query_service/test_positions_router.py",
        "tests/unit/services/query_service/services/test_position_service.py"
      ],
      "request": {
        "headers": {
          "X-Correlation-Id": "corr-api-example-001"
        },
        "path": {
          "portfolio_id": "PF_API_EXAMPLE_001"
        },
        "query": {
          "as_of_date": "2026-03-28"
        }
      },
      "response": {
        "status": 200,
        "body": {
          "portfolio_id": "PF_API_EXAMPLE_001",
          "as_of_date": "2026-03-28",
          "positions": [
            {
              "security_id": "SEC_SYNTH_EQ_001",
              "quantity": "125.0000",
              "market_value": "100000.00",
              "currency": "USD"
            }
          ],
          "correlation_id": "corr-api-example-001"
        }
      },
      "sensitivity": {
        "syntheticOnly": true,
        "redactionPolicy": "No client, account, person, or raw bank identifiers."
      }
    },
    {
