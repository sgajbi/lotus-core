      "id": "event-replay-idempotency-conflict",
      "category": "conflict_idempotency",
      "service": "event_replay_service",
      "family": "Control-Plane And Policy",
      "method": "POST",
      "path": "/ingestion/jobs/{job_id}/retry",
      "sourceTests": [
        "tests/unit/services/event_replay_service/test_ingestion_retry_commands.py",
        "tests/unit/services/event_replay_service/test_ingestion_operations.py"
