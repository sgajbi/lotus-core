      "request": {
        "headers": {
          "X-Correlation-Id": "corr-api-example-006",
          "Idempotency-Key": "idem-api-example-retry"
        },
        "path": {
          "job_id": "JOB_SYNTH_001"
        },
        "body": {
          "dry_run": false
        }
      },
      "response": {
        "status": 409,
        "body": {
          "code": "INGESTION_RETRY_DUPLICATE_BLOCKED",
          "message": "Retry is blocked because an equivalent replay is already recorded.",
          "correlation_id": "corr-api-example-006",
          "idempotency_key": "idem-api-example-retry",
          "details": {
            "outcome": "duplicate_blocked"
          }
        }
      },
      "sensitivity": {
        "syntheticOnly": true,
        "redactionPolicy": "Job and idempotency identifiers are synthetic."
      }
