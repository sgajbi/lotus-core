      "id": "ingestion-dependency-timeout",
      "category": "dependency_timeout",
      "service": "ingestion_service",
      "family": "Write Ingress",
      "method": "POST",
      "path": "/ingest/transactions",
      "sourceTests": [
        "tests/unit/services/ingestion_service/routers/test_publish_errors.py",
        "tests/integration/services/ingestion_service/test_ingestion_routers.py"
      ],
      "request": {
        "headers": {
          "X-Correlation-Id": "corr-api-example-007",
          "Idempotency-Key": "idem-api-example-timeout"
        },
        "body": {
          "transactions": [
            {
              "transaction_id": "TXN_SYNTH_TIMEOUT",
              "portfolio_id": "PF_API_EXAMPLE_001",
              "security_id": "SEC_SYNTH_EQ_001"
            }
          ]
        }
      },
      "response": {
        "status": 503,
        "headers": {
          "Retry-After": "5"
        },
        "body": {
          "code": "INGESTION_PUBLISH_FAILED",
          "message": "Kafka dependency did not confirm delivery before timeout.",
          "correlation_id": "corr-api-example-007",
          "details": {
            "dependency": "kafka",
            "retryable": true,
            "publish_state": "delivery_timeout"
          }
        }
      },
      "sensitivity": {
        "syntheticOnly": true,
        "redactionPolicy": "No raw downstream exception text is exposed."
      }
    },
