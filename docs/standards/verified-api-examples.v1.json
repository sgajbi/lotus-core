          "idempotency_key": "idem-api-example-conflict",
          "details": {
            "conflict_reason": "payload_fingerprint_mismatch"
          }
        }
      },
      "sensitivity": {
        "syntheticOnly": true,
        "redactionPolicy": "Payload identifiers are synthetic."
