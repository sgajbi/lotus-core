{
  "schema_version": "lotus-core.event-contract-test-pack.v1",
  "owning_repository": "lotus-core",
  "issue": "sgajbi/lotus-core#604",
  "gate_command": "make event-contract-test-pack-guard",
  "accepted_event_schema_versions": [
    "1.0.0"
  ],
  "required_contract_dimensions": [
    "topic name and event family",
    "event type and version",
    "required payload fields and unknown-field rejection",
    "correlation, trace, idempotency, source-system, and schema-version metadata",
    "partition/key policy",
    "DLQ payload and replay envelope",
    "compatibility rules for additive and breaking changes"
  ],
  "compatibility_policy": {
    "additive_change": "Allowed only when consumers tolerate the field through an explicit versioned compatibility contract; governed event models otherwise fail fast on unknown fields.",
    "breaking_change": "Requires a new schema version, updated event-family/direct-topic catalog entry, producer and consumer tests, DLQ/replay evidence, and downstream migration notes.",
    "unknown_field_policy": "forbid"
  },
  "evidence_profiles": {
