[importlinter]
root_packages =
    services
    portfolio_common
include_external_packages = True

[importlinter:contract:query_service_routers_do_not_import_repositories]
name = Query service routers should not import repositories directly
type = forbidden
source_modules =
    services.query_service.app.routers
forbidden_modules =
    services.query_service.app.repositories

[importlinter:contract:common_library_no_fastapi_dependency]
name = portfolio_common should not depend on FastAPI
type = forbidden
source_modules =
    portfolio_common
forbidden_modules =
    fastapi
