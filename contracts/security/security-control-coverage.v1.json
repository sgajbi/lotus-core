{
  "schema_version": "security-control-coverage.v1",
  "owning_repository": "lotus-core",
  "control_boundary": "Static contract coverage for lotus-core FastAPI app bootstrap and service-level security controls. This contract proves controls are installed or explicitly scoped; it is not live ingress, IAM, or penetration-test evidence.",
  "default_local_posture": {
    "cors_policy": "deny_browser_cross_origin_unless_LOTUS_HTTP_CORS_ALLOW_ORIGINS_is_set",
    "enterprise_authz": "default_disabled_for_local_compatibility",
    "enterprise_audit": "write_audit_middleware_installed_on_business_http_apps",
    "metrics_access": "internal_open_unless_LOTUS_METRICS_ACCESS_TOKEN_is_set",
    "strict_config": "local_fallback_unless_LOTUS_CORE_STRICT_CONFIG_VALIDATION_or_non_local_ENVIRONMENT_enables_fail_closed_validation"
  },
  "required_shared_controls": [
    "standard_http_bootstrap",
    "secure_response_headers",
    "cors_policy",
    "metrics_access_policy",
    "safe_unhandled_error_response"
  ],
  "apps": [
