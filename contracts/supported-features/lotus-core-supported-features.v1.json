  ],
  "guard_command": "make supported-features-guard",
  "capabilities": [
    {
      "id": "portfolio-account-source-record",
      "display_name": "Portfolio and account source of record",
      "owner": "lotus-core",
      "status": "supported",
      "implementation_modules": [
        "src/services/query_service/app/routers/portfolios.py",
        "src/services/query_service/app/routers/cash_accounts.py",
        "src/services/query_service/app/routers/cash_balances.py",
        "src/services/query_service/app/routers/instruments.py",
        "src/services/query_service/app/routers/positions.py"
      ],
      "routes": [
        "/portfolios/{portfolio_id}",
        "/portfolios/{portfolio_id}/positions",
        "/portfolios/{portfolio_id}/cash-balances"
      ],
      "source_data_products": [
        "HoldingsAsOf:v1"
      ],
      "tests": [
        "tests/integration/services/query_service/test_main_app.py",
        "tests/integration/services/query_service/test_positions_router_dependency.py",
        "tests/integration/services/query_service/test_cash_balances_router.py",
        "tests/unit/services/query_service"
      ],
      "validation_evidence": [
        "make lotus-core-validate",
        "scripts/certify_lotus_core_app.py",
        "docs/architecture/RFC-0082-downstream-endpoint-consumer-and-test-coverage-audit.md"
      ],
      "safe_demo_claims": [
        {
          "claim": "Core provides recorded portfolio, cash, instrument, and holding source truth for downstream apps.",
          "evidence_refs": [
            "wiki/API-Surface.md",
            "contracts/domain-data-products/lotus-core-products.v1.json"
          ]
        }
      ],
      "prohibited_claims": [
        {
          "claim": "Performance, risk, advice, reporting, or execution conclusions are provided by this capability.",
          "owning_service_boundary": "lotus-performance, lotus-risk, lotus-advise, lotus-report, lotus-manage, or execution/OMS systems",
          "evidence_refs": [
            "docs/architecture/RFC-0082-contract-family-inventory.md"
          ]
        }
      ],
      "limitations": [
        "Source truth is bounded to persisted Core records and governed source-data products."
      ],
      "downstream_ownership_caveats": [
        "Gateway and Workbench compose user experiences but do not own Core source truth."
      ]
    },
